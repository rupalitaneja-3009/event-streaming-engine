# ─── Service Ports ───────────────────────────────────────────────
EVENT_PRODUCER_PORT=3010
EVENT_CONSUMER_PORT=3011
NOTIFICATION_GATEWAY_PORT=3012

# ─── Kafka ───────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=event-streaming-engine
KAFKA_GROUP_ID=event-consumer-group
KAFKA_TOPIC_NOTIFICATIONS=notifications
KAFKA_TOPIC_EMAILS=emails
KAFKA_TOPIC_WEBHOOKS=webhooks
KAFKA_TOPIC_DLQ=dead-letter-queue

# ─── MongoDB ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/event_streaming

# ─── Redis ───────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380

# ─── Inter-service URLs ──────────────────────────────────────────
NOTIFICATION_GATEWAY_URL=http://localhost:3012

# ─── SMS — MSG91 (https://msg91.com) ─────────────────────────────
# Sign up → Dashboard → API Keys → create auth key
# Sender ID: register a 6-char DLT-approved sender (e.g. NOTIFY)
MSG91_API_KEY=
MSG91_SENDER_ID=
MSG91_ROUTE=4
# Set to "true" to log SMS instead of calling MSG91 (no API key needed)
SMS_DEV_MODE=true

# ─── SMS — Fast2SMS (alternative provider) ───────────────────────
# Sign up → Dev API → get API key
FAST2SMS_API_KEY=

# Active SMS provider: msg91 | fast2sms
SMS_PROVIDER=msg91

# ─── Email ───────────────────────────────────────────────────────
# Dev: use Mailhog (docker-compose). Prod: SendGrid or SMTP.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=notifications@eventstream.local
EMAIL_DEV_MODE=true

# SendGrid (optional, for production)
SENDGRID_API_KEY=

# ─── Webhook ─────────────────────────────────────────────────────
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_MAX_RETRIES=3

# ─── AI Notification Summarizer ──────────────────────────────────
# Provider: openai | anthropic
AI_PROVIDER=openai

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Set to "true" to return a mock summary without calling any AI API
AI_DEV_MODE=true

# ─── Consumer retry ──────────────────────────────────────────────
DELIVERY_MAX_RETRIES=3
DELIVERY_RETRY_BASE_DELAY_MS=2000
